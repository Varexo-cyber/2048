# Neon PostgreSQL Database URL
# Vervang dit met je eigen database URL
# Format: postgresql://user:password@host/database?sslmode=require
VITE_DATABASE_URL=your_neon_database_url_here

# Twilio WhatsApp API Credentials
# Ga naar https://www.twilio.com/try-twilio om een account aan te maken
# Voor WhatsApp messaging naar jouw telefoonnummers
TWILIO_ACCOUNT_SID=your_twilio_account_sid_here
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here

# SMTP Credentials voor email
SMTP_USER=your_email_here
SMTP_PASSWORD=your_gmail_app_password_here
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
